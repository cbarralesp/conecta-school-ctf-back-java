app:
  ai:
    provider: deepseek
    openai:
      api-key: ${OPENAI_API_KEY:pega-aqui-tu-api-key-local}
      model: ${OPENAI_MODEL:gpt-5.4-mini}
      base-url: ${OPENAI_BASE_URL:https://api.openai.com/v1}
      timeout-seconds: ${OPENAI_TIMEOUT_SECONDS:45}
    gemini:
      api-key: ${GEMINI_API_KEY:pega-aqui-tu-api-key-local}
      model: ${GEMINI_MODEL:gemini-3.5-flash}
      base-url: ${GEMINI_BASE_URL:https://generativelanguage.googleapis.com/v1beta}
      timeout-seconds: ${GEMINI_TIMEOUT_SECONDS:45}
    deepseek:
      api-key: ${DEEPSEEK_API_KEY:pega-aqui-tu-api-key-local}
      model: ${DEEPSEEK_MODEL:deepseek-v4-pro}
      base-url: ${DEEPSEEK_BASE_URL:https://api.deepseek.com}
      timeout-seconds: ${DEEPSEEK_TIMEOUT_SECONDS:45}
